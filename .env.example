# ============================================================
# ResumeAI — Environment Configuration
# ============================================================
# Copy this file to `.env` and fill in the values.
# NEVER commit the .env file to version control.
# ============================================================

# ---------- General ----------
NODE_ENV=development
APP_NAME=ResumeAI
APP_VERSION=1.0.0

# ---------- Backend Server ----------
SERVER_PORT=5000
SERVER_HOST=localhost
API_PREFIX=/api/v1

# ---------- Frontend ----------
NEXT_PUBLIC_API_URL=http://localhost:5000/api/v1
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---------- Database (MySQL via XAMPP) ----------
DATABASE_URL="mysql://root:@localhost:3306/resume_ai_dev"
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# ---------- JWT Authentication ----------
JWT_ACCESS_SECRET=your-access-secret-change-this-in-production-min-32-chars
JWT_REFRESH_SECRET=your-refresh-secret-change-this-in-production-min-32-chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
JWT_ISSUER=resumeai.local
ADMIN_EMAILS=owner@example.com
NEXT_PUBLIC_ADMIN_EMAILS=owner@example.com

# ---------- Google OAuth 2.0 ----------
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:5000/api/v1/auth/google/callback

# ---------- OpenAI ----------
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_ORG_ID=
OPENAI_DEFAULT_MODEL=gpt-4o-mini
OPENAI_PREMIUM_MODEL=gpt-4o
OPENAI_MAX_RETRIES=3
OPENAI_TIMEOUT_MS=30000

# ---------- Gemini ----------
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash

# ---------- Rate Limiting ----------
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_FREE=60
RATE_LIMIT_MAX_PRO=300

# ---------- CORS ----------
CORS_ORIGIN=http://localhost:3000

# ---------- Logging ----------
LOG_LEVEL=debug
LOG_FORMAT=combined
LOG_DIR=logs

# ---------- File Upload ----------
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=10

# ---------- Encryption ----------
ENCRYPTION_KEY=your-32-char-encryption-key-here!

# ---------- Feature Flags ----------
FEATURE_AI_ENABLED=true
FEATURE_GOOGLE_AUTH_ENABLED=true
FEATURE_RAZORPAY_ENABLED=false
FEATURE_EXPORT_DOCX_ENABLED=false

# ---------- Razorpay (Phase 2) ----------
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=
# RAZORPAY_WEBHOOK_SECRET=

# ---------- Email (Phase 2) ----------
# SMTP_HOST=smtp.mailtrap.io
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# EMAIL_FROM=noreply@resumeai.local
